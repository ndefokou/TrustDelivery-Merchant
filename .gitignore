frontend/.pnp.js

# --- Environment variables ---
.env
.env.*
!.env.example

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
*.iml

# --- OS generated files ---
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Logs ---
*.log
logs/

# --- Debug / Coverage ---
coverage/
